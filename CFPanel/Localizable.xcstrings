    "Deployment history loads here on demand so the project directory page does not prefetch build history.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Bereitstellungsverlauf wird hier bei Bedarf geladen, damit die Projektverzeichnisseite den Build-Verlauf nicht vorab abruft."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El historial de implementación se carga aquí a pedido para que la página del directorio del proyecto no busque previamente el historial de compilación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'historique des déploiements se charge ici à la demande afin que la page du répertoire du projet ne pré-récupère pas l'historique de construction."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La cronologia di distribuzione viene caricata qui su richiesta in modo che la pagina della directory del progetto non esegua il pre-fetch della cronologia della build."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プロジェクトディレクトリページがビルド履歴をプリフェッチしないように、デプロイ履歴はオンデマンドでここにロードされます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O histórico de implantação carrega aqui sob demanda para que a página do diretório do projeto não busque previamente o histórico de compilação."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "История развертывания загружается здесь по запросу, чтобы страница каталога проекта не выполняла предварительную выборку истории сборки."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "部署历史在此处按需加载，从而使项目目录页面不会预取构建历史。"
          }
        }
      }
    },
