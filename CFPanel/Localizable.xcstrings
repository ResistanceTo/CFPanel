    "Traffic Snapshot works best as a compact health readout before you drill into Traffic Analytics.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Datenverkehr-Snapshot eignet sich am besten als kompakte Statusanzeige, bevor Sie tiefer in die Datenverkehr-Analysen einsteigen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La instantánea de tráfico funciona mejor como un indicador de estado compacto antes de profundizar en el análisis de tráfico."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'instantané de trafic est idéal en tant qu'indicateur d'état compact avant d'approfondir les analyses de trafic."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'istantanea del traffico funziona al meglio come un indicatore di stato compatto prima di approfondire l'analisi del traffico."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "トラフィックのスナップショットは、トラフィック分析を掘り下げる前のコンパクトな稼働状態の読み取りとして最適です。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O snapshot de tráfego funciona melhor como uma leitura de integridade compacta antes de você detalhar a análise de tráfego."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Снимок трафика лучше всего подходит в качестве компактной оценки работоспособности перед углублением в аналитику трафика."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在深入研究流量分析之前，流量快照最适合作为紧凑的健康状态读数。"
          }
        }
      }
    },
