    "Applies an aggressive JavaScript challenge to all visitors. Use during active DDoS attacks only.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wendet eine aggressive JavaScript-Herausforderung auf alle Besucher an. Nur während aktiver DDoS-Angriffe verwenden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplica un desafío de JavaScript agresivo a todos los visitantes. Úselo solo durante ataques DDoS activos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Applique un défi JavaScript agressif à tous les visiteurs. À utiliser uniquement lors d'attaques DDoS actives."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Applica una sfida JavaScript aggressiva a tutti i visitatori. Utilizzare solo durante attacchi DDoS attivi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべての訪問者に強力なJavaScriptチャレンジを適用します。アクティブなDDoS攻撃中にのみ使用してください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplica um desafio JavaScript agressivo a todos os visitantes. Use apenas durante ataques DDoS ativos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Применяет агрессивную проверку JavaScript ко всем посетителям. Используйте только во время активных DDoS-атак."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "向所有访客应用强力的 JavaScript 质询。仅在遭受 DDoS 攻击时使用。"
          }
        }
      }
    },
