    "Add one URL per line. Use this when you only want to flush a subset of assets.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie eine URL pro Zeile hinzu. Verwenden Sie dies, wenn Sie nur eine Teilmenge der Assets bereinigen möchten."
          }
        },
        "es": {
          "stringUnit": {
