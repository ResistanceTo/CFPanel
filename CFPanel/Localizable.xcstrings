    "Purge Everything clears the active site's cached assets globally and can increase origin load until the cache is warm again.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„Alles bereinigen“ löscht die zwischengespeicherten Assets der aktiven Website global und kann die Auslastung des Ursprungsservers erhöhen, bis der Cache wieder warm ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Purgar todo borra los activos almacenados en caché del sitio activo a nivel mundial y puede aumentar la carga de origen hasta que la caché se vuelva a calentar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tout purger efface globalement les ressources mises en cache du site actif et peut augmenter la charge d'origine jusqu'à ce que le cache soit à nouveau chaud."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Svuota tutto cancella le risorse memorizzate nella cache del sito attivo a livello globale e può aumentare il carico dell'origine finché la cache non si riscalda di nuovo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「すべてをパージ」を実行すると、アクティブなサイトのキャッシュされたアセットがグローバルにクリアされ、キャッシュが再び温まるまでオリジンの負荷が増加する可能性があります。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Limpar tudo apaga globalmente os ativos em cache do site ativo e pode aumentar a carga de origem até que o cache seja restabelecido."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Очистка всего кэша удаляет кэшированные ресурсы активного сайта во всей сети и может увеличить нагрузку на источник до повторного заполнения кэша."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“清除所有缓存”将全局清除当前站点的缓存资源，在缓存重新预热前可能会增加源站负载。"
          }
        }
      }
    },
    "Purge Listed URLs": {
      "localizations": {
