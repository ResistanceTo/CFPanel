    "Add Zone Settings:Read/Edit and Cache Purge for SSL/TLS, security level, HSTS, cache controls, and incident response.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie die Berechtigungen „Zoneneinstellungen:Lesen/Bearbeiten“ und „Cache-Bereinigung“ für SSL/TLS, Sicherheitsstufe, HSTS, Cache-Steuerung und Störfallreaktion hinzu."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añada los permisos de Configuración de zona:Leer/Editar y Purgar caché para SSL/TLS, nivel de seguridad, HSTS, controles de caché y respuesta a incidentes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez les autorisations \"Paramètres de zone:Lecture/Écriture\" et \"Purge du cache\" pour le SSL/TLS, le niveau de sécurité, HSTS, les contrôles de cache et la réponse aux incidents."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi le autorizzazioni \"Impostazioni zona:Lettura/Modifica\" e \"Svuotamento cache\" per SSL/TLS, livello di sicurezza, HSTS, controlli cache e gestione degli incidenti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "SSL/TLS、セキュリティレベル、HSTS、キャッシュコントロール、インシデント対応のために、「ゾーン設定:読み取り/編集」と「キャッシュパージ」の権限を追加してください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione as permissões Configurações de Zona:Ler/Editar e Purga de Cache para SSL/TLS, nível de segurança, HSTS, controles de cache e resposta a incidentes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавьте разрешения Настройки зоны:Чтение/Редактирование и Очистка кэша для SSL/TLS, уровня безопасности, HSTS, управления кэшем и реагирования на инциденты."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加“区域设置:读取/编辑”和“缓存清除”权限，以便管理 SSL/TLS、安全级别、HSTS、缓存控制 and 事件响应。"
          }
        }
      }
    },
