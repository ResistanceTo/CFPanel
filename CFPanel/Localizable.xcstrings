    "Create a scoped API token in Cloudflare Dashboard, then paste it here with the matching account ID.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstellen Sie ein bereichsbezogenes API-Token im Cloudflare-Dashboard und fügen Sie es hier mit der passenden Konto-ID ein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cree un token de API con alcance en el panel de Cloudflare, luego péguelo aquí junto con el ID de cuenta correspondiente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Créez un jeton d'API ciblé dans le tableau de bord Cloudflare, puis collez-le ici avec l'ID de compte correspondant."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea un token API con ambito nel pannello di controllo Cloudflare, quindi incollalo qui con l'ID account corrispondente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflareダッシュボードでスコープ指定されたAPIトークンを作成し、一致するアカウントIDと一緒にここに貼り付けます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Crie um token de API com escopo no Painel da Cloudflare e cole-o aqui junto com o ID da conta correspondente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Создайте токен API с ограниченной областью действия в панели управления Cloudflare, затем вставьте его сюда вместе с соответствующим ID аккаунта."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Cloudflare 控制面板中创建一个有作用域的 API 令牌，然后将其与相应的帐户 ID 一起粘贴到此处。"
          }
        }
      }
    },
    "Create a scoped API token in Cloudflare Dashboard, then paste it into CFPanel.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstellen Sie im Cloudflare-Dashboard ein bereichsbezogenes API-Token und fügen Sie es in CFPanel ein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cree un token de API con alcance en el Panel de Cloudflare y luego péguelo en CFPanel."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Créez un jeton d'API restreint dans le tableau de bord Cloudflare, puis collez-le dans CFPanel."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea un token API con ambito nella dashboard di Cloudflare, quindi incollalo in CFPanel."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "CloudflareダッシュボードでスコープされたAPIトークンを作成し、CFPanelに貼り付けます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Crie um token de API com escopo no Painel da Cloudflare e cole-o no CFPanel."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Создайте токен API с ограниченной областью действия в панели управления Cloudflare, а затем вставьте его в CFPanel."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
