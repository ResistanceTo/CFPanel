    "Cloudflare will provision Email Routing and tell you which DNS records must exist before mail can flow.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflare stellt das E-Mail-Routing bereit und teilt Ihnen mit, welche DNS-Einträge vorhanden sein müssen, bevor E-Mails gesendet werden können."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflare aprovisionará el enrutamiento de correo electrónico y le indicará qué registros DNS deben existir antes de que el correo pueda fluir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflare provisionnera le routage des e-mails et vous indiquera quels enregistrements DNS doivent exister avant que les e-mails ne puissent circuler."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflare configurerà l'instradamento delle e-mail e ti indicherà quali record DNS devono esistere prima che le e-mail possano transitare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflareはメールルーティングをプロビジョニングし、メールが流れる前にどのDNSレコードが存在する必要があるかを通知します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A Cloudflare provisionará o Roteamento de E-mail e informará quais registros DNS devem existir antes que as mensagens comecem a fluir."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflare настроит маршрутизацию электронной почты и сообщит, какие записи DNS должны существовать до начала отправки почты."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflare 将配置电子邮件路由，并告诉您在邮件流通之前必须存在哪些 DNS 记录。"
          }
        }
      }
    },
