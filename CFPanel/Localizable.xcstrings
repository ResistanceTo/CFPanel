    "Start from the current site snapshot, then branch into analytics, performance, or incident handling.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beginnen Sie mit dem aktuellen Website-Snapshot und verzweigen Sie dann in Analytics, Leistung oder Vorfallsbehandlung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comience con la instantánea del sitio actual y luego divídase en análisis, rendimiento o gestión de incidentes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Commencez par l'instantané actuel du site, puis passez aux analyses, aux performances ou à la gestion des incidents."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
