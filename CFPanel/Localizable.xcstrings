    "The selected zone has no records matching your filter.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die ausgewählte Zone hat keine Einträge, die Ihrem Filter entsprechen."
          }
        },
        "es": {
