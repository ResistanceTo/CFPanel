    "Only the most aggressive threats are challenged. Use with caution.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur die aggressivsten Bedrohungen werden herausgefordert. Mit Vorsicht verwenden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo se desafían las amenazas más agresivas. Usar con precaución."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seules les menaces les plus agressives font l'objet d'un défi. À utiliser avec précaution."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vengono sottoposte a verifica solo le minacce più aggressive. Usare con cautela."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最も攻撃的な脅威のみがチャレンジを受けます。注意して使用してください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Apenas as ameaças mais agressivas são desafiadas. Use com cuidado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Блокируются только самые агрессивные угрозы. Используйте с осторожностью."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅挑战最具攻击性的威胁。请谨慎使用。"
          }
        }
      }
    },
    "Open 24H, 7D, or 30D trend charts and request health for the active site.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffnen Sie 24-Stunden-, 7-Tage- oder 30-Tage-Trenddiagramme und fordern Sie den Anfragezustand für die aktive Website an."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abra gráficos de tendencias de 24 horas, 7 días o 30 días y solicite el estado de las solicitudes para el sitio activo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrez des graphiques de tendance sur 24 heures, 7 jours ou 30 jours et demandez l'état des requêtes pour le site actif."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apri i grafici delle tendenze a 24 ore, 7 giorni o 30 giorni e richiedi lo stato delle richieste per il sito attivo."
          }
        },
