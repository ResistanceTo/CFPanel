    "Add and verify at least one destination address before configuring a catch-all.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie mindestens eine Zieladresse hinzu und verifizieren Sie diese, bevor Sie eine Catch-all-Regel konfigurieren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añada y verifique al menos una dirección de destino antes de configurar una regla general (catch-all)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez et vérifiez au moins une adresse de destination avant de configurer une règle générique."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi e verifica almeno un indirizzo di destinazione prima di configurare un catch-all."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キャッチオールを構成する前に、少なくとも1つの宛先アドレスを追加して確認してください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione e verifique pelo menos um endereço de destino antes de configurar um catch-all."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавьте и подтвердите хотя бы один адрес назначения перед настройкой универсального правила."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在配置全部捕获规则之前，请添加并验证至少一个目标地址。"
          }
        }
      }
    },
