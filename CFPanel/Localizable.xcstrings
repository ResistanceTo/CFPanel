    "This page focuses on safe, high-frequency Email Routing tasks: setup checks, destination addresses, catch-all forwarding, and rule visibility.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Seite konzentriert sich auf sichere, häufige E-Mail-Routing-Aufgaben: Einrichtungsprüfungen, Zieladressen, Catch-All-Weiterleitung und Regel-Sichtbarkeit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta página se centra en tareas seguras y de alta frecuencia de enrutamiento de correo electrónico: comprobaciones de configuración, direcciones de destino, reenvío comodín y visibilidad de reglas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette page se concence sur les tâches de routage d'e-mails sécurisées et fréquentes : vérifications de configuration, adresses de destination, transfert de type catch-all et visibilité des règles."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa pagina si concentra sulle attività di routing e-mail sicure e frequenti: verifiche di configurazione, indirizzi di destinazione, inoltro catch-all e visibilità delle regole."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このページは、セットアップチェック、宛先アドレス、キャッチオール転送、ルールの可視化など、安全で頻度の高いメールルーティングタスクに焦点を当てています。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta página se concentra em tarefas seguras e frequentes de Roteamento de E-mail: verificações de configuração, endereços de destino, encaminhamento catch-all e visibilidade de regras."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эта страница посвящена безопасным и частым задачам маршрутизации электронной почты: проверке настроек, адресам назначения, пересылке catch-all и видимости правил."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此页面专注于安全且高频的电子邮件路由任务：设置检查、目标地址、Catch-all 转发和规则可见性。"
          }
        }
      }
    },
    "This page focuses on sending subdomain visibility and DNS readiness. Creation and deletion stay off mobile by default.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Seite konzentriert sich auf die Sichtbarkeit von Sende-Subdomains und die DNS-Bereitschaft. Erstellung und Löschung bleiben standardmäßig mobil deaktiviert."
          }
        },
        "es": {
