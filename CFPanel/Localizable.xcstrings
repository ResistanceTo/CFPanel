    "Pick the scope set here first. The choices on this screen are the exact scopes CFPanel will send to Cloudflare.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie zuerst hier das Bereichsset aus. Die Optionen auf diesem Bildschirm sind die genauen Bereiche, die CFPanel an Cloudflare sendet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Seleccione primero el conjunto de alcances aquí. Las opciones en esta pantalla son los alcances exactos que CFPanel enviará a Cloudflare."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sélectionnez d'abord l'ensemble d'autorisations ici. Les choix affichés sur cet écran correspondent aux autorisations exactes que CFPanel enverra à Cloudflare."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Seleziona prima qui l'insieme degli ambiti. Le opzioni in questa schermata sono gli ambiti esatti che CFPanel invierà a Cloudflare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まずここでスコープセットを選択してください。この画面の選択肢は、CFPanelがCloudflareに送信する正確なスコープです。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecione o conjunto de escopos aqui primeiro. As escolhas nesta tela são os escopos exatos que o CFPanel enviará para a Cloudflare."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сначала выберите набор областей доступа здесь. Выбранные на этом экране области доступа будут отправлены в Cloudflare."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请先在此处选择作用域集合。此屏幕上的选项即为 CFPanel 将发送给 Cloudflare 的确切作用域。"
          }
        }
      }
    },
