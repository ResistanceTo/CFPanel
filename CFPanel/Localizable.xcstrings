    "Settings only controls startup preference. Active site switching and site status live in Sites.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einstellungen steuern nur die Startpräferenz. Das Wechseln der aktiven Website und der Website-Status befinden sich unter 'Websites'."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La configuración solo controla la preferencia de inicio. El cambio de sitio activo y el estado del sitio se encuentran en Sitios."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les paramètres contrôlent uniquement la préférence de démarrage. Le changement de site actif et le statut du site se trouvent dans Sites."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impostazioni controlla solo la preferenza di avvio. Il cambio del sito attivo e lo stato del sito risiedono in Siti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定は起動時の設定のみを制御します。アクティブなサイトの切り替えとサイトステータスは[Sites]にあります。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As configurações controlam apenas a preferência de inicialização. A alteração do site ativo e o status do site ficam em Sites."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Настройки управляют только предпочтениями при запуске. Переключение активного сайта и его статус находятся в разделе «Сайты»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置仅控制启动偏好。活动站点切换和站点状态位于“站点”中。"
          }
        }
      }
    },
