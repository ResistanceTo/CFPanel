    "CFPanel": {
      "shouldTranslate": false
    },
    "CFPanel exists in part because Cloudflare has made powerful infrastructure tools accessible to a much wider range of developers and teams.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "CFPanel existiert zum Teil, weil Cloudflare leistungsstarke Infrastruktur-Tools für eine viel breitere Palette von Entwicklern und Teams zugänglich gemacht hat."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "CFPanel existe en parte porque Cloudflare ha hecho que las potentes herramientas de infraestructura sean accesibles para una gama mucho más amplia de desarrolladores y equipos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "CFPanel existe en partie parce que Cloudflare a rendu de puissants outils d'infrastructure accessibles à un éventail beaucoup plus large de développeurs et d'équipes."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "CFPanel esiste in parte perché Cloudflare ha reso potenti strumenti di infrastruttura accessibili a una gamma molto più ampia di sviluppatori e team."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "CFPanelが存在する理由の一部は、Cloudflareが強力なインフラツールをより幅広い開発者やチームに提供したことにあります。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O CFPanel existe em parte porque a Cloudflare tornou ferramentas de infraestrutura poderosas acessíveis a uma gama muito mais ampla de desenvolvedores e equipes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "CFPanel существует отчасти потому, что Cloudflare сделала мощные инструменты инфраструктуры доступными для гораздо более широкого круга разработчиков и команд."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "CFPanel 的存在，部分原因在于 Cloudflare 让更广泛的开发者和团队能够使用强大的基础设施工具。"
          }
        }
      }
    },
    "CFPanel is an independent third-party client built for the Cloudflare ecosystem using Cloudflare's public APIs. Cloudflare names and product marks belong to Cloudflare, Inc.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "CFPanel ist ein unabhängiger Drittanbieter-Client, der unter Verwendung der öffentlichen APIs von Cloudflare für das Cloudflare-Ökosystem entwickelt wurde. Die Namen und Produktmarken von Cloudflare gehören Cloudflare, Inc."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "CFPanel es un cliente de terceros independiente creado para el ecosistema de Cloudflare utilizando las API públicas de Cloudflare. Los nombres y marcas de productos de Cloudflare pertenecen a Cloudflare, Inc."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "CFPanel est un client tiers indépendant conçu pour l'écosystème Cloudflare utilisant les API publiques de Cloudflare. Les noms et marques de produits Cloudflare appartiennent à Cloudflare, Inc."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "CFPanel è un client di terze parti indipendente creato per l'ecosistema Cloudflare utilizzando le API pubbliche di Cloudflare. I nomi e i marchi dei prodotti Cloudflare appartengono a Cloudflare, Inc."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "CFPanelは、CloudflareのパブリックAPIを使用してCloudflareエコシステム向けに構築された独立したサードパーティ製のクライアントです。Cloudflareの名称および製品マークは、Cloudflare, Inc.に帰属します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O CFPanel é um cliente de terceiros independente construído para o ecossistema da Cloudflare usando as APIs públicas da Cloudflare. Os nomes e marcas de produtos da Cloudflare pertencem à Cloudflare, Inc."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "CFPanel — это независимый сторонний клиент, созданный для экосистемы Cloudflare с использованием публичных API Cloudflare. Названия и товарные знаки Cloudflare принадлежат Cloudflare, Inc."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "CFPanel 是一款使用 Cloudflare 公共 API 为 Cloudflare 生态系统构建的独立第三方客户端。Cloudflare 的名称和产品标志归 Cloudflare, Inc. 所有。"
          }
        }
      }
    },
    "Challenge suspicious clients with malformed or missing browser headers.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fordern Sie verdächtige Clients mit fehlerhaften oder fehlenden Browser-Headern heraus."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desafíe a los clientes sospechosos con encabezados de navegador malformados o faltantes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Défiez les clients suspects avec des en-têtes de navigateur mal formés ou manquants."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Metti alla prova i client sospetti con intestazioni del browser non valide o mancanti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "不正な形式または欠落しているブラウザヘッダーを持つ不審なクライアントにチャレンジを提示します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desafie clientes suspeitos com cabeçalhos de navegador malformados ou ausentes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проверять подозрительных клиентов с некорректными или отсутствующими заголовками браузера."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "向带有格式错误或缺失浏览器请求头的可疑客户端发起质询。"
          }
        }
      }
    },
    "Challenges only high-confidence threats based on Cloudflare's threat intelligence.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fordert nur Bedrohungen mit hoher Vertrauenswürdigkeit heraus, basierend auf Cloudflares Bedrohungserkennung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desafía solo a las amenazas de alta confianza basadas en la inteligencia de amenazas de Cloudflare."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ne défie que les menaces à haut niveau de confiance basées sur l'intelligence des menaces de Cloudflare."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mette alla prova solo le minacce ad alta affidabilità in base all'intelligence sulle minacce di Cloudflare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflareの脅威インテリジェンスに基づいて、確度の高い脅威のみにチャレンジを提示します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desafia apenas ameaças de alta confiança com base na inteligência de ameaças da Cloudflare."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проверять только высоковероятные угрозы на основе данных анализа угроз Cloudflare."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅针对基于 Cloudflare 威胁情报确定的高置信度威胁发起质询。"
          }
        }
      }
    },
    "Challenges visitors with a moderate threat score. Balanced default.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fordert Besucher mit einer moderaten Bedrohungsbewertung heraus. Ausgewogener Standard."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desafía a los visitantes con una puntuación de amenaza moderada. Predeterminado equilibrado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Défie les visiteurs ayant un score de menace modéré. Option par défaut équilibrée."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mette alla prova i visitatori con un punteggio di minaccia moderato. Valore predefinito bilanciato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "中程度の脅威スコアを持つ訪問者にチャレンジを提示します。バランスの取れたデフォルト。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desafia visitantes com uma pontuação de ameaça moderada. Padrão equilibrado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проверять посетителей с умеренным уровнем угрозы. Сбалансированное значение по умолчанию."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对具有中等威胁分数的访客发起质询。均衡的默认设置。"
          }
        }
      }
    },
    "Challenges visitors with any elevated threat score.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fordert Besucher mit einer erhöhten Bedrohungsbewertung heraus."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desafía a los visitantes con cualquier puntuación de amenaza elevada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Défie les visiteurs ayant un score de menace élevé."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mette alla prova i visitatori con qualsiasi punteggio di minaccia elevato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "脅威スコアが上昇しているすべての訪問者にチャレンジを提示します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desafia visitantes com qualquer pontuação de ameaça elevada."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проверять посетителей с любым повышенным уровнем угрозы."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对具有任何高威胁分数的访客发起质询。"
          }
        }
      }
    },
    "Checking for a saved token and restoring your Cloudflare session.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Überprüfung auf ein gespeichertes Token und Wiederherstellung Ihrer Cloudflare-Sitzung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Buscando un token guardado y restaurando su sesión de Cloudflare."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vérification d'un jeton enregistré et restauration de votre session Cloudflare."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Verifica di un token salvato e ripristino della sessione Cloudflare."
          }
        },
        "ja": {
          "stringUnit": {
