    "Namespaces and key previews. Open this list to load KV only.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Namespaces und Schlüssel-Vorschauen. Öffnen Sie diese Liste, um nur KV zu laden."
          }
        },
        "es": {
