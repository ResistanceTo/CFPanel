    "Choose a workspace tool from the sidebar to manage the active site.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie ein Workspace-Tool aus der Seitenleiste aus, um die aktive Website zu verwalten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elija una herramienta de espacio de trabajo de la barra lateral para administrar el sitio activo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez un outil d'espace de travail dans la barre latérale pour gérer le site actif."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli uno strumento dell'area di lavoro dalla barra laterale per gestire il sito attivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクティブなサイトを管理するには、サイドバーからワークスペースツールを選択してください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha uma ferramenta de espaço de trabalho na barra lateral para gerenciar o site ativo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите инструмент рабочей области на боковой панели для управления активным сайтом."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从侧边栏选择工作区工具以管理活动站点。"
          }
        }
      }
    },
    "Choose an analytics or incident workflow from the sidebar.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie einen Analyse- oder Störfall-Workflow aus der Seitenleiste."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elija un flujo de trabajo de análisis o incidentes de la barra lateral."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez un flux de travail d'analyse ou d'incident dans la barre latérale."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli un flusso di lavoro per le analisi o gli incidenti dalla barra laterale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サイドバーから分析またはインシデントのワークフローを選択してください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha um fluxo de trabalho de análise ou incidente na barra lateral."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите рабочий процесс аналитики или реагирования на инциденты на боковой панели."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从侧边栏选择分析或事件工作流。"
          }
        }
      }
    },
    "Choose browser-based OAuth when you want flexible scopes, or use an account token when you need a direct manual setup.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie browserbasiertes OAuth, wenn Sie flexible Bereiche wünschen, oder verwenden Sie ein Konto-Token, wenn Sie eine direkte manuelle Einrichtung benötigen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elija OAuth basado en navegador cuando desee alcances flexibles, o use un token de cuenta cuando necesite una configuración manual directa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez l'OAuth via navigateur pour des autorisations flexibles, ou utilisez un jeton de compte pour une configuration manuelle directe."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli OAuth basato su browser per ambiti flessibili o usa un token account se hai bisogno di una configurazione manuale diretta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "柔軟なスコープが必要な場合はブラウザベースのOAuthを選択し、直接手動で設定する必要がある場合はアカウントトークンを使用してください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha o OAuth baseado em navegador quando desejar escopos flexíveis, ou use um token de conta quando precisar de uma configuração manual direta."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите OAuth через браузер, если вам нужны гибкие области доступа, или используйте токен аккаунта для прямой ручной настройки."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当您需要灵活的作用域时，请选择基于浏览器的 OAuth；当您需要直接的手动设置时，请使用帐户令牌。"
          }
        }
      }
    },
