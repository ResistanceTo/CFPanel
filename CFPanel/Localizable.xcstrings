    "You can also help by sharing CFPanel, filing useful feedback, starring the project, or leaving an App Store review.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie können auch helfen, indem Sie CFPanel teilen, nützliches Feedback senden, das Projekt mit einem Stern versehen oder eine Bewertung im App Store hinterlassen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "También puede ayudar compartiendo CFPanel, enviando comentarios útiles, dando una estrella al proyecto o dejando una reseña en la App Store."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez également aider en partageant CFPanel, en envoyant des commentaires utiles, en ajoutant une étoile au projet ou en laissant un avis sur l'App Store."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Puoi aiutare anche condividendo CFPanel, inviando feedback utili, aggiungendo una stella al progetto o lasciando una recensione su App Store."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "CFPanelを共有したり、役立つフィードバックを送信したり、プロジェクトにスターを付けたり、App Storeでレビューを残すことでも支援できます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você também pode ajudar compartilhando o CFPanel, enviando feedbacks úteis, dando uma estrela ao projeto ou deixando uma avaliação na App Store."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы также можете помочь, поделившись CFPanel, отправив полезный отзыв, поставив звезду проекту или оставив отзыв в App Store."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您也可以通过分享 CFPanel、提交有用的反馈意见、在项目中点亮 Star，或者在 App Store 留下评价来提供帮助。"
          }
        }
      }
    },
