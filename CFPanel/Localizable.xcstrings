    "Location record content. Advanced users can paste Cloudflare-compatible LOC data.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Inhalt des Standort-Eintrags. Fortgeschrittene Benutzer können Cloudflare-kompatible LOC-Daten einfügen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Contenido del registro de ubicación. Los usuarios avanzados pueden pegar datos LOC compatibles con Cloudflare."
