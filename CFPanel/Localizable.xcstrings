          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La zone sélectionnée ne contient aucun enregistrement correspondant à votre filtre."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
