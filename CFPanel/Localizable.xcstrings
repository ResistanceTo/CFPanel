    "Detailed request health becomes available after analytics load for the active site.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Detaillierte Informationen zum Zustand der Anfragen sind verfügbar, nachdem die Analysedaten für die aktive Website geladen wurden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El estado detallado de las solicitudes estará disponible una vez que se carguen los análisis del sitio activo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'état de santé détaillé des requêtes devient disponible après le chargement des analyses pour le site actif."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo stato di integrità dettagliato delle richieste diventa disponibile dopo il caricamento delle analisi per il sito attivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクティブなサイト of 分析データが読み込まれた後、詳細なリクエストヘルスが利用可能になります。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O status de integridade detalhado da solicitação fica disponível após o carregamento das análises do site ativo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подробная информация о работоспособности запросов станет доступна после загрузки аналитики для активного сайта."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "活动网站的分析数据加载后，即可查看详细的请求健康状况。"
          }
        }
      }
    },
    "Development Mode and Always Online are grouped here as delivery controls.": {
      "localizations": {
