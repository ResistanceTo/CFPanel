      }
    },
    "Operational data is requested from Cloudflare as needed. Request diagnostics redact resource identifiers before local storage.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Betriebsdaten werden nach Bedarf von Cloudflare angefordert. Die Anfragediagnose schwärzt Ressourcenidentifikatoren vor der lokalen Speicherung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los datos operativos se solicitan a Cloudflare según sea necesario. El diagnóstico de solicitudes redacta los identificadores de recursos antes del almacenamiento local."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les données opérationnelles sont demandées à Cloudflare selon les besoins. Les diagnostics de requête masquent les identifiants de ressources avant le stockage local."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I dati operativi vengono richiesti a Cloudflare in base alle esigenze. La diagnostica delle richieste oscura gli identificatori delle risorse prima dell'archiviazione locale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "運用データは必要に応じてCloudflareから要求されます。リクエスト診断では、ローカルに保存される前にリソース識別情報が編集（非表示に）されます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os dados operacionais são solicitados ao Cloudflare conforme necessário. O diagnóstico de solicitação oculta os identificadores de recursos antes do armazenamento local."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Операционные данные запрашиваются у Cloudflare по мере необходимости. Диагностика запросов скрывает идентификаторы ресурсов перед локальным сохранением."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "根据需要从 Cloudflare 请求运行数据。请求诊断会在本地存储前脱敏资源标识符。"
          }
        }
      }
    },
