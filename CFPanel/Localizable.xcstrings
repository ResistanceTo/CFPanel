    "Inspect request volume, traffic quality, cache behavior, and end-user performance.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Untersuchen Sie das Anfragevolumen, die Traffic-Qualität, das Cache-Verhalten und die Endbenutzer-Performance."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Inspecciona el volumen de solicitudes, la calidad del tráfico, el comportamiento de la caché y el rendimiento del usuario final."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Inspectez le volume de requêtes, la qualité du trafic, le comportement du cache et les performances des utilisateurs finaux."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ispeziona il volume delle richieste, la qualità del traffico, il comportamento della cache e le prestazioni dell'utente finale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リクエスト量、トラフィック品質、キャッシュの動作、およびエンドユーザーのパフォーマンスを検査します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Inspecione o volume de solicitações, a qualidade do tráfego, o comportamento do cache e o desempenho do usuário final."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Анализируйте объем запросов, качество трафика, поведение кэша и производительность для конечных пользователей."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "检查请求量、流量质量、缓存行为和终端用户性能。"
          }
        }
      }
    },
