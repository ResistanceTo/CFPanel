    "Use a scoped API token so CFPanel only gets the permissions you intend.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie einen berechtigten API-Token, damit CFPanel nur die von Ihnen beabsichtigten Berechtigungen erhält."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Use un token de API limitado para que CFPanel solo obtenga los permisos que usted elija."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez un jeton API restreint afin que CFPanel obtienne uniquement les autorisations que vous souhaitez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizza un token API con ambito in modo que CFPanel ottenga solo le autorizzazioni previste."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "CFPanelが意図した権限のみを取得できるように、スコープが制限されたAPIトークンを使用してください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use um token de API com escopo para que o CFPanel obtenha apenas as permissões desejadas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте токен API с ограниченной областью действия, чтобы CFPanel получал только те разрешения, которые вы планируете предоставить."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用有范围限制的 API 令牌，以便 CFPanel 仅获取您预期的权限。"
          }
        }
      }
    },
    "Use Certificate for the base64 certificate payload.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie 'Zertifikat' für den base64-codierten Zertifikatsinhalt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Use Certificado para la carga útil del certificado en base64."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez Certificat pour la charge utile du certificat en base64."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizza Certificato per il payload del certificato base64."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "base64証明書ペイロードには証明書を使用します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use Certificado para o payload do certificado base64."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте Сертификат для полезной нагрузки сертификата в формате base64."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用证书获取 base64 证书负载。"
          }
        }
      }
    },
    "Use Cloudflare DNS scan review to inspect discovered records before adding them to the zone.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie die DNS-Scan-Überprüfung von Cloudflare, um gefundene Einträge zu überprüfen, bevor Sie sie der Zone hinzufügen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Use la revisión del escaneo de DNS de Cloudflare para inspeccionar los registros descubiertos antes de agregarlos a la zona."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez la vérification de l'analyse DNS de Cloudflare pour inspecter les enregistrements découverts avant de les ajouter à la zone."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizza la verifica della scansione DNS di Cloudflare per ispezionare i record individuati prima di aggiungerli alla zona."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "検出されたレコードをゾーンに追加する前に、Cloudflare DNSスキャンレビューを使用して検査します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use a revisão de varredura de DNS do Cloudflare para inspecionar os registros descobertos antes de adicioná-los à zona."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте проверку результатов сканирования DNS от Cloudflare для проверки обнаруженных записей перед их добавлением в зону."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在将发现的记录添加到区域之前，请使用 Cloudflare DNS 扫描审查来检查它们。"
          }
        }
      }
    },
    "Use host or wildcard patterns such as `example.com/*` or `api.example.com/*`.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie Host- oder Wildcard-Muster wie `example.com/*` oder `api.example.com/*`."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Use patrones de host o comodín como `example.com/*` o `api.example.com/*`."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez des modèles d'hôte ou génériques tels que `example.com/*` ou `api.example.com/*`."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizza pattern host o jolly come `example.com/*` o `api.example.com/*`."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "`example.com/*`や`api.example.com/*`などのホストまたはワイルドカードのパターンを使用します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use padrões de host ou curinga, como `example.com/*` ou `api.example.com/*`."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте шаблоны хостов или подстановочные знаки, такие как `example.com/*` или `api.example.com/*`."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用主机或通配符模式，例如 `example.com/*` 或 `api.example.com/*`。"
          }
        }
      }
    },
    "Use Tag for issue/issuewild/iodef and Value for the CA or contact value.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie 'Tag' für issue/issuewild/iodef und 'Wert' für die CA oder den Kontaktwert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Use Etiqueta para el problema/problema salvaje/iodef y Valor para la CA o valor de contacto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez Balise pour issue/issuewild/iodef et Valeur pour l'AC ou la valeur de contact."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizza Tag per issue/issuewild/iodef e Valore per la CA o il valore del contatto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "issue/issuewild/iodefにはタグを使用し、CAまたは連絡先値には値を使用します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use Tag para issue/issuewild/iodef e Valor para a AC ou valor do contato."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте Тег для issue/issuewild/iodef и Значение для центра сертификации (CA) или контактных данных."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对于 issue/issuewild/iodef 使用“标签”，对于 CA 或联系方式使用“值”。"
          }
        }
      }
    },
    "Use the same analytics range here to inspect cache efficiency and content distribution without opening the traffic trend page.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie hier denselben Analysebereich, um die Cache-Effizienz und Inhaltsverteilung zu überprüfen, ohne die Seite mit dem Datenverkehrstrend zu öffnen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Use el mismo rango de análisis aquí para inspeccionar la eficiencia de la caché y la distribución de contenido sin abrir la página de tendencias de tráfico."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez la même plage d'analyses ici pour inspecter l'efficacité du cache et la distribution du contenu sans ouvrir la page de tendance du trafic."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizza lo stesso intervallo di analisi qui per ispezionare l'efficienza della cache e la distribuzione dei contenuti senza aprire la pagina sull'andamento del traffico."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "トラフィック傾向ページを開くことなく、ここで同じ分析範囲を使用してキャッシュ効率とコンテンツ配信を検査します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use o mesmo intervalo de análise aqui para inspecionar a eficiência do cache e a distribuição de conteúdo sem abrir a página de tendências de tráfego."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте тот же диапазон аналитики здесь для проверки эффективности кэша и распределения контента без открытия страницы тенденций трафика."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在此处使用相同的分析范围来检查缓存效率和内容分发，而无需打开流量趋势页面。"
          }
        }
      }
    },
    "Use these actions when you need a fast response on the road. They affect the active site immediately.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie diese Aktionen, wenn Sie unterwegs eine schnelle Reaktion benötigen. Sie wirken sich sofort auf die aktive Website aus."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Use estas acciones cuando necesite una respuesta rápida en el camino. Afectan al sitio activo de inmediato."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez ces actions lorsque vous avez besoin d'une réponse rapide en déplacement. Elles affectent le site actif immédiatement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizza queste azioni quando hai bisogno di una risposta rapida fuori sede. Influiscono immediatamente sul sito attivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "外出先で迅速な対応が必要な場合は、これらのアクションを使用してください。アクティブなサイトにすぐに影響を与えます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use essas ações quando precisar de uma resposta rápida na estrada. Elas afetam o site ativo imediatamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте эти действия, когда вам нужна быстрая реакция в пути. Они немедленно влияют на активный сайт."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当您在旅途中需要快速响应时，请使用这些操作。它们会立即影响活动站点。"
          }
        }
      }
    },
    "Use these headline metrics for a fast check, then open a workflow below when you need more detail.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie diese Hauptkennzahlen für eine schnelle Überprüfung und öffnen Sie dann unten einen Workflow, wenn Sie weitere Details benötigen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Use estas métricas principales para una comprobación rápida, luego abra un flujo de trabajo a continuación cuando necesite más detalles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez ces mesures clés pour une vérification rapide, puis ouvrez un flux de travail ci-dessous si vous avez besoin de plus de détails."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizza queste metriche principali per un controllo rapido, quindi apri un flusso di lavoro di seguito quando hai bisogno di maggiori dettagli."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これらのヘッドライン指標を使用して素早く確認し、さらに詳細が必要な場合は以下のワークフローを開きます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use essas métricas principais para uma verificação rápida e abra um fluxo de trabalho abaixo quando precisar de mais detalhes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте эти ключевые показатели для быстрой проверки, а затем откройте рабочий процесс ниже, если вам нужны подробности."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用这些关键指标进行快速检查，然后在需要更多细节时打开下方的个别工作流。"
          }
        }
      }
    },
    "Use these phases when you need to block, challenge, or rate-limit incoming traffic.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie diese Phasen, wenn Sie eingehenden Datenverkehr blockieren, herausfordern oder ratenbegrenzen müssen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Use estas fases cuando necesite bloquear, desafiar o limitar la velocidad del tráfico entrante."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez ces phases lorsque vous devez bloquer, défier ou limiter le débit du trafic entrant."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizza queste fasi quando è necessario bloccare, verificare o limitare la velocità del traffico in entrata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "流入するトラフィックをブロック、チャレンジ、またはレート制限する必要がある場合は、これらのフェーズを使用します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use estas fases quando precisar bloquear, desafiar ou limitar a taxa do tráfego de entrada."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте эти фазы, когда вам нужно заблокировать, проверить или ограничить скорость входящего трафика."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当您需要阻止、提问挑战或限制传入流量的速率时，请使用这些阶段。"
          }
        }
      }
    },
    "Use these phases when you need to steer requests, tune cache behavior, or change origin handling.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie diese Phasen, wenn Sie Anfragen steuern, das Cache-Verhalten anpassen oder die Verarbeitung auf dem Ursprungsserver ändern müssen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Use estas fases cuando necesite dirigir solicitudes, ajustar el comportamiento de la caché o cambiar el manejo del origen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez ces phases lorsque vous devez orienter les requêtes, ajuster le comportement du cache ou modifier la gestion de l'origine."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizza queste fasi quando è necessario indirizzare le richieste, ottimizzare il comportamento della cache o modificare la gestione dell'origine."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リクエストの誘導、キャッシュ動作の調整、またはオリジン処理の変更が必要な場合は、これらのフェーズを使用します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use estas fases quando precisar direcionar solicitações, ajustar o comportamento do cache ou alterar o tratamento do servidor de origem."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте эти фазы, когда вам нужно направить запросы, настроить поведение кэша или изменить обработку на исходном сервере."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当您需要引导请求、调整缓存行为或更改源站处理方式时，请使用这些阶段。"
          }
        }
      }
    },
    "Use this for active incidents or obvious malicious traffic. This is reversible, but it affects live visitor experience immediately.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie dies bei aktiven Vorfällen oder offensichtlich böswilligem Datenverkehr. Dies ist umkehrbar, wirkt sich jedoch sofort auf das Besuchererlebnis aus."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Use esto para incidentes activos o tráfico malicioso obvio. Esto es reversible, pero afecta la experiencia del visitante en vivo de inmediato."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez cette option en cas d'incidents actifs ou de trafic malveillant évident. C'est réversible, mais cela affecte immédiatement l'expérience des visiteurs réels."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizza questa opzione per incidenti attivi o traffico palesemente dannoso. È reversibile, ma influisce immediatamente sull'esperienza dei visitatori in tempo reale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "進行中のインシデントや明らかな悪意のあるトラフィックに対してこれを使用します。これは元に戻せますが、実際の訪問者の体験に即座に影響します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use isso para incidentes ativos ou tráfego malicioso óbvio. Isso é reversível, mas afeta a experiência dos visitantes ativos imediatamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Режим «Под атакой» можно отключить, но он сразу же меняет то, как Cloudflare проверяет входящий трафик."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在发生实际事件或发现明显恶意流量时使用此选项。这是可逆的，但会立即影响在线访问者体验。"
          }
        }
      }
    },
    "Use this section during active incidents when you need immediate mitigation or cache purge tools.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie diesen Abschnitt bei aktiven Vorfällen, wenn Sie sofortige Schadensbegrenzung oder Tools zum Leeren des Caches benötigen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Use esta sección durante incidentes activos cuando necesite herramientas de mitigación inmediata o purga de caché."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez cette section lors d'incidents actifs lorsque vous avez besoin d'outils d'atténuation immédiate ou de purge du cache."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizza questa sezione durante gli incidenti attivi quando hai bisogno di mitigazione immediata o di strumenti per svuotare la cache."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "即時の緩和策またはキャッシュパージツールが必要なアクティブなインシデント時に、このセクションを使用します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use esta seção durante incidentes ativos quando precisar de mitigação imediata ou ferramentas de limpeza de cache."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте этот раздел во время активных инцидентов, когда вам нужны средства немедленного смягчения последствий или очистки кэша."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在发生实际事件且需要立即缓解或清除缓存工具时，请使用此部分。"
          }
        }
      }
    },
    "Use this section to review security posture and manage the standing policies that shape traffic handling.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie diesen Abschnitt, um das Sicherheitsniveau zu überprüfen und die bestehenden Richtlinien zu verwalten, die die Verarbeitung des Datenverkehrs bestimmen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Use esta sección para revisar la postura de seguridad y administrar las políticas vigentes que dan forma al manejo del tráfico."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez cette section pour examiner la posture de sécurité et gérer les politiques permanentes qui façonnent la gestion du trafic."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizza questa sezione per verificare lo stato della sicurezza e gestire le regole permanenti che determinano la gestione del traffico."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セキュリティ態勢を確認し、トラフィック処理を形成する常設ポリシーを管理するために、このセクションを使用します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use esta seção para revisar a postura de segurança e gerenciar as políticas em vigor que moldam o tratamento do tráfego."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте этот раздел для анализа состояния безопасности и управления постоянными политиками, определяющими обработку трафика."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用此部分审查安全状况并管理决定流量处理的常备策略。"
          }
        }
      }
    },
