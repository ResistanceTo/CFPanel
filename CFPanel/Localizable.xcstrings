    "Enable HTTP Strict Transport Security to instruct browsers to only connect via HTTPS.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivieren Sie HTTP Strict Transport Security, um Browser anzuweisen, nur Verbindungen über HTTPS herzustellen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Active la seguridad de transporte estricta de HTTP (HSTS) para indicar a los navegadores que solo se conecten a través de HTTPS."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez la sécurité de transport stricte HTTP (HSTS) pour indiquer aux navigateurs de se connecter uniquement via HTTPS."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Abilita HTTP Strict Transport Security per istruire i browser a connettersi solo tramite HTTPS."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブラウザにHTTPS経由でのみ接続するように指示するために、HTTP Strict Transport Security（HSTS）を有効にします。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ativar o HTTP Strict Transport Security para instruir os navegadores a se conectarem apenas via HTTPS."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включить HTTP Strict Transport Security (HSTS), чтобы браузеры подключались только по HTTPS."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用 HTTP 安全传输协议（HSTS）以指示浏览器仅通过 HTTPS 连接。"
          }
        }
      }
    },
