    "DNSSEC delegation signer. Fill Key Tag, Algorithm, Digest Type, and Digest.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "DNSSEC-Delegationsunterzeichner. Füllen Sie Schlüssel-Tag, Algorithmus, Digest-Typ und Digest aus."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Firmante de delegación de DNSSEC. Rellene Etiqueta de clave, Algoritmo, Tipo de resumen y Resumen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Signataire de délégation DNSSEC. Remplissez le tag de clé, l'algorithme, le type de digest et le digest."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Firmatario di delega DNSSEC. Compila Tag chiave, Algoritmo, Tipo di digest e Digest."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "DNSSECの委任署名者（DS）。キータグ、アルゴリズム、ダイジェストタイプ、およびダイジェストを入力してください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Signatário de delegação DNSSEC. Preencha Tag de chave, Algoritmo, Tipo de resumo e Resumo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подписант делегирования DNSSEC. Заполните поля «Тег ключа», «Алгоритм», «Тип дайджеста» и «Дайджест»."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "DNSSEC 委派签署者。填写密钥标签、算法、摘要类型和摘要。"
          }
        }
      }
    },
    "DNSSEC key material. Fill Flags, Protocol, Algorithm, and Public Key.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "DNSSEC-Schlüsselmaterial. Füllen Sie Flags, Protokoll, Algorithmus und öffentlichen Schlüssel aus."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Material de clave DNSSEC. Rellene Indicadores, Protocolo, Algoritmo y Clave pública."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Matériel de clé DNSSEC. Remplissez les drapeaux, le protocole, l'algorithme et la clé publique."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Materiale della chiave DNSSEC. Compila Flag, Protocollo, Algoritmo e Chiave pubblica."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "DNSSECキーマテリアル。フラグ、プロトコル、アルゴリズム、および公開鍵を入力してください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Material de chave DNSSEC. Preencha Flags, Protocolo, Algoritmo e Chave pública."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Материал ключей DNSSEC. Заполните поля «Флаги», «Протокол», «Алгоритм» и «Открытый ключ»."
