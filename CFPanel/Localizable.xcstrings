            "value": "Zwischenspeichern aller statischen Inhalte, einschließlich Antworten mit Abfrage-Strings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Almacene en caché todo el contenido estático, incluidas las respuestas con cadenas de consulta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
