    "Enable receiving, review DNS readiness, manage destination addresses, and inspect routing rules.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivieren Sie den Empfang, überprüfen Sie die DNS-Bereitschaft, verwalten Sie Zieladressen und überprüfen Sie Routing-Regeln."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Active la recepción, revise la preparación de DNS, administre las direcciones de destino e inspeccione las reglas de enrutamiento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez la réception, examinez la préparation du DNS, gérez les adresses de destination et inspectez les règles de routage."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Abilita la ricezione, controlla la conformità DNS, gestisci gli indirizzi di destinazione e ispeziona le regole di instradamento."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "受信の有効化、DNSの準備状況の確認、宛先アドレスの管理、ルーティングルールの検査を行います。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ativar o recebimento, analisar a prontidão do DNS, gerenciar endereços de destino e inspecionar regras de roteamento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включить прием, проверить готовность DNS, управлять адресами назначения и проверять правила маршрутизации."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用接收、检查 DNS 就绪情况、管理目标地址并检查路由规则。"
          }
        }
      }
    },
