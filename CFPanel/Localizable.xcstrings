    "Review these records before making broader zone changes.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Überprüfen Sie diese Einträge, bevor Sie umfassendere Änderungen an der Zone vornehmen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Revise estos registros antes de realizar cambios más amplios en la zona."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Veuillez examiner ces enregistrements antes d'apporter des modifications plus larges à la zone."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esamina questi record prima di apportar modifiche più ampie alla zona."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "より広範なゾーン変更を行う前に、これらのレコードを確認してください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Revise estes registros antes de fazer alterações mais amplas na zona."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Проверьте эти записи перед внесением более широких изменений в зону."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在进行更广泛的区域更改之前，请先检查这些记录。"
          }
        }
      }
    },
    "Rewrite mixed-content links to HTTPS when possible.": {
