          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在のサイトのスナップショットから開始し、分析、パフォーマンス、またはインシデント処理へと分岐します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Comece com o snapshot atual do site e, em seguida, navegue para análises, desempenho ou tratamento de incidentes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Начните со снимка текущего сайта, а затем перейдите к аналитике, производительности или обработке инцидентов."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从当前的站点快照开始，然后分支到分析、性能或事件处理。"
          }
        }
      }
    },
    "Start here for deployable web properties and release-oriented workflows tied to your Cloudflare account.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beginnen Sie hier für bereitstellbare Webinhalte und Release-orientierte Workflows, die mit Ihrem Cloudflare-Konto verknüpft sind."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comience aquí para propiedades web desplegables y flujos de trabajo orientados a lanzamientos vinculados a su cuenta de Cloudflare."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Commencez ici pour les propriétés web déployables et les flux de travail orientés versions liés à votre compte Cloudflare."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Inizia da qui per proprietà web distribuibili e flussi di lavoro orientati al rilascio collegati al tuo account Cloudflare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflareアカウントに関連付けられた、デプロイ可能なWebプロパティおよびリリース指向のワークフローは、ここから開始します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Comece aqui para propriedades web implantáveis e fluxos de trabalho orientados a lançamentos vinculados à sua conta do Cloudflare."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Начните здесь для развертываемых веб-ресурсов и рабочих процессов подготовки выпусков, связанных с вашей учетной записью Cloudflare."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从这里开始部署 Web 属性和与您的 Cloudflare 帐户绑定的面向发布的发布工作流。"
          }
        }
      }
    },
    "Start New Scan": {
      "localizations": {
        "de": {
          "stringUnit": {
