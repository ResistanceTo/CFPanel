    "Paste the 32-character Cloudflare account ID that owns this API token so CFPanel can verify it against /accounts/{account_id}/tokens/verify.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie die 32-stellige Cloudflare-Konto-ID ein, zu der dieses API-Token gehört, damit CFPanel sie mit /accounts/{account_id}/tokens/verify überprüfen kann."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pegue el ID de cuenta de Cloudflare de 32 caracteres que posee este token de API para que CFPanel pueda verificarlo con /accounts/{account_id}/tokens/verify."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Collez l'identifiant de compte Cloudflare à 32 caractères auquel appartient ce jeton d'API afin que CFPanel puisse le vérifier via /accounts/{account_id}/tokens/verify."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Incolla l'ID account Cloudflare di 32 caratteri a cui appartiene questo token API, così CFPanel potrà verificarlo tramite /accounts/{account_id}/tokens/verify."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このAPIトークンを所有する32文字のCloudflareアカウントIDを貼り付けてください。CFPanelが /accounts/{account_id}/tokens/verify で確認します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cole o ID da conta Cloudflare de 32 caracteres que possui este token de API para que o CFPanel possa verificá-lo em /accounts/{account_id}/tokens/verify."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вставьте 32-символьный ID аккаунта Cloudflare, которому принадлежит этот API-токен, чтобы CFPanel мог проверить его через /accounts/{account_id}/tokens/verify."
          }
        },
        "zh-Hans": {
          "stringUnit": {
