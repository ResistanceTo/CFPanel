    "Bypass edge cache for up to 3 hours while making changes.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Umgehen Sie den Edge-Cache beim Vornehmen von Änderungen für bis zu 3 Stunden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Evite la caché perimetral durante un máximo de 3 horas mientras realiza cambios."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Contournez le cache de périphérie pendant 3 heures maximum lorsque vous effectuez des modifications."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Escludi la cache edge per un massimo di 3 ore durante l'apporto di modifiche."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "変更を行う間、最大3時間エッジキャッシュをバイパスします。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ignore o cache de borda por até 3 horas ao fazer alterações."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Обход пограничного кэша на время до 3 часов при внесении изменений."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在进行更改时绕过边缘缓存最多 3 小时。"
          }
        }
      }
    },
