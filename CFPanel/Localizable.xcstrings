    "Purge build cache or delete the project without loading domain inventory.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bereinigen Sie den Build-Cache oder löschen Sie das Projekt, ohne das Domain-Inventar zu laden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Purgue la caché de compilación o elimine el proyecto sin cargar el inventario de dominios."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Purgez le cache de build ou supprimez le projet sans charger l'inventaire des domaines."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Svuota la cache di compilazione o elimina il progetto senza caricare l'inventario dei domini."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ドメインインベントリを読み込まずに、ビルドキャッシュをパージするかプロジェクトを削除します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Limpe o cache de compilação ou exclua o projeto sem carregar o inventário de domínios."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Очистите кэш сборки или удалите проект без загрузки списка доменов."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在不加载域清单的情况下清除构建缓存或删除项目。"
          }
        }
      }
    },
    "Purge Everything": {
      "localizations": {
        "de": {
