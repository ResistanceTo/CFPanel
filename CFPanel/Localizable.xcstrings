    "To change account scope, sign out and reconnect with a different token.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Um den Kontobereich zu ändern, melden Sie sich ab und verbinden Sie sich mit einem anderen Token erneut."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Para cambiar el alcance de la cuenta, cierra sesión y vuelve a conectarte con otro token."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour modifier la portée du compte, déconnectez-vous puis reconnectez-vous avec un autre jeton."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per cambiare l'ambito dell'account, esci e riconnettiti con un token diverso."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アカウントの対象範囲を変更するには、サインアウトして別のトークンで再接続してください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Para mudar o escopo da conta, saia e conecte-se novamente com um token diferente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Чтобы изменить область действия аккаунта, выйдите из системы и подключитесь снова с другим токеном."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如需更改帐户范围，请先退出登录，再使用其他令牌重新连接。"
          }
        }
      }
    },
    "To change OAuth scopes, sign out and authorize again with a different permission set.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Um die OAuth-Bereiche zu ändern, melden Sie sich ab und autorisieren Sie sich erneut mit einem anderen Berechtigungssatz."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Para cambiar los alcances de OAuth, cierre la sesión y autorice nuevamente con un conjunto de permisos diferente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour modifier les autorisations OAuth, déconnectez-vous et autorisez à nouveau avec un autre ensemble de permissions."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per modificare gli ambiti OAuth, disconnettiti e autorizza nuovamente con un set di permessi diverso."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "OAuthスコープを変更するには、サインアウトして別の権限セットで再度認可してください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Para alterar os escopos do OAuth, encerre a sessão e autorize novamente com um conjunto diferente de permissões."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Чтобы изменить области доступа OAuth, выйдите из системы и авторизуйтесь снова с другим набором разрешений."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如需更改 OAuth 作用域，请退出登录并使用不同的权限集重新进行授权。"
          }
        }
      }
    },
    "Toggle Under Attack Mode or purge cache for the active site.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivieren Sie den 'Under Attack'-Modus oder leeren Sie den Cache für die aktive Website."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Active el Modo bajo ataque o purgue la caché para el sitio activo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez le mode Under Attack ou purgez le cache du site actif."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Attiva la modalità Sotto attacco o svuota la cache per il sito attivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクティブなサイトの「Under Attackモード」の切り替え、またはキャッシュをパージします。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Alterne o Modo sob ataque ou limpe o cache para o site ativo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Переключите режим «Под атакой» или очистите кэш для активного сайта."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为活动站点切换“Under Attack 模式”或清除缓存。"
          }
        }
      }
    },
