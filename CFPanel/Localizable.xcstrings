    "Signing out removes the saved Cloudflare credential from this device and clears the local workspace session.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durch das Abmelden werden die gespeicherten Cloudflare-Anmeldedaten von diesem Gerät entfernt und die lokale Arbeitsbereichssitzung gelöscht."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cerrar sesión elimina la credencial guardada de Cloudflare de este dispositivo y borra la sesión del espacio de trabajo local."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Se déconnecter supprime l'identifiant Cloudflare enregistré de cet appareil et efface la session de l'espace de travail local."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La disconnessione rimuove le credenziali Cloudflare salvate da questo dispositivo e cancella la sessione dell'area di lavoro locale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サインアウトすると、保存されているCloudflareの資格情報がこのデバイスから削除され、ローカルのワークスペースセッションがクリアされます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Encerrar a sessão remove a credencial salva da Cloudflare deste dispositivo e limpa a sessão local do espaço de trabalho."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выход удаляет сохраненные учетные данные Cloudflare с этого устройства и очищает сессию локального рабочего пространства."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "退出登录将从该设备中移除已保存的 Cloudflare 凭据，并清除本地的工作区会话。"
          }
        }
      }
    },
