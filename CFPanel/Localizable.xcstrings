    "A catch-all rule exists, but its forward target could not be resolved.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es existiert eine Catch-all-Regel, aber ihr Weiterleitungsziel konnte nicht aufgelöst werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Existe una regla general (catch-all), pero su destino de reenvío no se pudo resolver."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une règle générique existe, mais sa cible de transfert n'a pas pu être résolue."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esiste una regola catch-all, ma non è stato possibile risolvere la sua destinazione di inoltro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キャッチオールルールが存在しますが、転送先を解決できませんでした。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Existe uma regra catch-all, mas seu destino de encaminhamento não pôde ser resolvido."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Существует универсальное правило (catch-all), но его цель пересылки не удалось разрешить."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "存在一条全部捕获规则，但无法解析其转发目标。"
          }
        }
      }
    },
    "A focused Cloudflare control room for iPhone and iPad.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein fokussiertes Cloudflare-Kontrollzentrum für iPhone und iPad."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una consola de control de Cloudflare enfocada para iPhone y iPad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un centre de contrôle Cloudflare dédié pour iPhone et iPad."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Una console di controllo Cloudflare dedicata per iPhone e iPad."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iPhoneおよびiPad用の特化したCloudflareコントロールルーム。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma central de controle Cloudflare dedicada para iPhone e iPad."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Специализированный центр управления Cloudflare для iPhone и iPad."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "专为 iPhone 和 iPad 打造的 Cloudflare 控制台。"
          }
        }
      }
    },
    "A focused third-party Cloudflare client for day-to-day infrastructure work using Cloudflare OAuth, scoped API tokens, and Cloudflare's public APIs.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein fokussierter Cloudflare-Drittanbieter-Client für die tägliche Infrastrukturarbeit unter Verwendung von Cloudflare OAuth, bereichsbezogenen API-Token und den öffentlichen APIs von Cloudflare."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un cliente de Cloudflare de terceros enfocado para el trabajo diario de infraestructura utilizando OAuth de Cloudflare, tokens de API con alcance y las API públicas de Cloudflare."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un client Cloudflare tiers dédié aux tâches d'infrastructure quotidiennes, utilisant l'OAuth Cloudflare, des jetons d'API ciblés et les API publiques de Cloudflare."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un client Cloudflare di terze parti dedicato al lavoro quotidiano sull'infrastruttura che utilizza Cloudflare OAuth, token API con ambito specifico e le API pubbliche di Cloudflare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflare OAuth、スコープ指定されたAPIトークン、およびCloudflareのパブリックAPIを使用する、日常のインフラ作業向けの特化したサードパーティ製Cloudflareクライアント。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um cliente Cloudflare de terceiros focado para o trabalho diário de infraestrutura usando Cloudflare OAuth, tokens de API com escopo e as APIs públicas da Cloudflare."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Специализированный сторонний клиент Cloudflare для повседневной работы с инфраструктурой с использованием Cloudflare OAuth, токенов API с ограниченной областью действия и публичных API Cloudflare."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一款专注于日常基础设施工作的第三方 Cloudflare 客户端，使用 Cloudflare OAuth、有作用域的 API 令牌以及 Cloudflare 的公共 API。"
          }
        }
      }
    },
