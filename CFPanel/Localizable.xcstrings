    "Support is optional. The goal is sustainable maintenance, not paywalls or feature unlocks.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Unterstützung ist optional. Das Ziel ist eine nachhaltige Wartung, nicht Bezahlschranken oder Funktionsfreischaltungen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El soporte es opcional. El objetivo es un mantenimiento sostenible, no muros de pago ni desbloqueos de funciones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le soutien est facultatif. L'objectif est une maintenance durable, et non des paywalls ou des déblocages de fonctionnalités."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il supporto è facoltativo. L'obiettivo è una manutenzione sostenibile, non paywall o sblocchi di funzionalità."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サポートは任意です。目標は持続可能なメンテナンスであり、ペイウォールや機能制限の解除ではありません。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O apoio é opcional. O objetivo é uma manutenção sustentável, não barreiras de pagamento ou desbloqueios de recursos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поддержка является добровольной. Цель — устойчивая поддержка проекта, а не платный доступ или разблокировка функций."
          }
        },
        "zh-Hans": {
