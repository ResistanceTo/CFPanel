    "Review account-level actions with filters for site scope, actor, and time range.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Konto-Aktionen überprüfen mit Filtern für Website-Bereich, Akteur und Zeitbereich."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Revisar las acciones a nivel de cuenta con filtros para el alcance del sitio, el actor y el rango de tiempo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Examiner les actions au niveau du compte avec des filtres pour la portée du site, l'acteur et la plage horaire."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esamina le azioni a livello di account con filtri per ambito del sito, attore e intervallo di tempo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サイトのスコープ、アクター、および時間範囲のフィルターを使用して、アカウントレベルのアクションを確認します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Rever ações no nível da conta com filtros para escopo do site, ator e intervalo de tempo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Просмотр действий на уровне учетной записи с фильтрами по сайту, исполнителю и диапазону времени."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "审查帐户级别的操作，并提供站点范围、操作员和时间范围的过滤器。"
          }
        }
      }
    },
    "Review cache efficiency, audience shape, and content distribution for the active site.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Cache-Effizienz, Zielgruppenzusammensetzung und Inhaltsverteilung für die aktive Website überprüfen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Revisar la eficiencia de la caché, la forma de la audiencia y la distribución del contenido para el sitio activo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Examiner l'efficacité du cache, le profil de l'audience et la distribution du contenu pour le site actif."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esamina l'efficienza della cache, la composizione del pubblico e la distribuzione dei contenuti per il sito attivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクティブなサイト의キャッシュ効率、オーディエンスの構成、およびコンテンツ配信を確認します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Rever a eficiência do cache, o perfil do público e a distribuição de conteúdo para o site ativo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Анализ эффективности кэша, структуры аудитории и распределения контента для активного сайта."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "审查活动站点的缓存效率、受众特征和内容分发。"
          }
        }
      }
    },
