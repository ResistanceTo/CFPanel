    },
    "Redirect all requests to HTTPS at the edge.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Leiten Sie alle Anfragen am Edge zu HTTPS weiter."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Redirigir todas las solicitudes a HTTPS en el perímetro (edge)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rediriger toutes les requêtes vers HTTPS à la périphérie."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Reindirizza tutte le richieste a HTTPS all'edge."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エッジですべてのリクエストをHTTPSにリダイレクトします。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Redirecionar todas as solicitações para HTTPS na borda."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перенаправлять все запросы на HTTPS на границе сети (edge)."
          }
