    "Paste a Cloudflare account token and its matching account ID. This path is precise, manual, and good for tightly scoped access.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie ein Cloudflare-Konto-Token und die passende Konto-ID ein. Dieser Pfad ist präzise, manuell und eignet sich für stark eingeschränkten Zugriff."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pegue un token de cuenta de Cloudflare y su ID de cuenta correspondiente. Esta ruta es precisa, manual y recomendada para un acceso con alcance muy limitado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Collez un jeton de compte Cloudflare et l'ID de compte correspondant. Cette méthode est précise, manuelle et idéale pour un accès restreint."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Incolla un token account Cloudflare e l'ID account corrispondente. Questo percorso è preciso, manuale e ideale per un accesso limitato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloudflareアカウントトークンと一致するアカウントIDを貼り付けます。この方法は正確で手動であり、制限されたアクセスに適しています。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cole um token de conta da Cloudflare e o ID de conta correspondente. Este caminho é preciso, manual e recomendado para acesso com escopo restrito."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вставьте токен аккаунта Cloudflare и соответствующий ID аккаунта. Это точный ручной метод настройки, который подходит для строго ограниченного доступа."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "粘贴 Cloudflare 帐户令牌及其匹配的帐户 ID。此路径是精确的手动操作，适用于受严格限制的访问权限。"
          }
        }
      }
    },
    "Paste an account token and the matching account ID.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie ein Konto-Token und die passende Konto-ID ein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pegue un token de cuenta y el ID de cuenta correspondiente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Collez un jeton de compte et l'ID de compte correspondant."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Incolla un token account e l'ID account corrispondente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アカウントトークンと一致するアカウントIDを貼り付けます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
